{
  "name": "pi-tmux-hub",
  "version": "0.1.0",
  "description": "tmux-native monitor for Pi coding-agent sessions.",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "tmux",
    "pi"
  ],
  "type": "module",
  "bin": {
    "pi-tmux-hub": "bin/pi-tmux-hub.js"
  },
  "scripts": {
    "test": "node --test",
    "snapshot": "node bin/pi-tmux-hub.js",
    "watch": "node bin/pi-tmux-hub.js --watch"
  },
  "engines": {
    "node": ">=20"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-tmux-hub-sensor.js"
    ]
  },
  "files": [
    "bin",
    "extensions",
    "src",
    "README.md",
    "LICENSE"
  ]
}
